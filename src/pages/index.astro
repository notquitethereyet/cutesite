---
import BaseLayout from '../components/layouts/BaseLayout.astro';
import Hero from '../components/sections/Hero.astro';
import About from '../components/sections/About.astro';
import Projects from '../components/sections/Projects.astro';
import Skills from '../components/sections/Skills.astro';
import Contact from '../components/sections/Contact.astro';
import Footer from '../components/sections/Footer.astro';

// Page metadata
const pageTitle = "Portfolio - Boid Fish Simulation";
const pageDescription = "Portfolio website with interactive boid fish simulation background";
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <Hero 
    name="John Doe"
    title="Full-Stack Developer & Designer"
    description="Creating innovative digital experiences with a focus on interactive web applications and creative coding."
  />
  
  <About />
  
  <Projects />
  
  <Skills />
  
  <Contact />
  
  <Footer />
</BaseLayout>
