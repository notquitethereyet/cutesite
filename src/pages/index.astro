---
import Layout from '../layouts/Layout.astro';
---

<Layout>
    <!-- Header/Hero Section -->
    <section class="hero-section min-h-screen flex flex-col justify-center items-center text-center p-8">
        <h1 class="text-5xl md:text-6xl font-bold mb-4 text-blue-900">John Doe</h1>
        <h2 class="text-2xl md:text-3xl mb-8 text-blue-700">Full-Stack Developer & Designer</h2>
        <p class="max-w-lg mb-8 text-lg">Creating innovative digital experiences with a focus on interactive web applications and creative coding.</p>
        <div class="flex flex-wrap justify-center gap-4">
            <a href="#contact" class="px-6 py-3 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition shadow-lg">Get in Touch</a>
            <a href="#projects" class="px-6 py-3 bg-transparent border-2 border-blue-600 text-blue-600 rounded-lg hover:bg-blue-50 transition shadow-lg">See My Work</a>
        </div>
    </section>
    
    <!-- About Section -->
    <section id="about" class="py-16 px-4 bg-white bg-opacity-90 section-transition">
        <div class="max-w-4xl mx-auto">
            <h2 class="text-3xl font-bold mb-8 text-center text-blue-900">About Me</h2>
            <div class="flex flex-col md:flex-row gap-8 items-center">
                <div class="md:w-1/3">
                    <div class="w-64 h-64 rounded-full bg-blue-200 mx-auto flex items-center justify-center">
                        <span class="text-6xl text-blue-500">JD</span>
                    </div>
                </div>
                <div class="md:w-2/3">
                    <p class="mb-4">Hello! I'm a passionate developer with expertise in creating interactive web experiences. I specialize in combining creative design with technical excellence to build engaging applications.</p>
                    <p class="mb-4">With over 5 years of experience in the industry, I've worked on a diverse range of projects from small business websites to complex enterprise applications. My approach combines clean code, intuitive user experiences, and innovative problem-solving.</p>
                    <p>When I'm not coding, you can find me exploring new technologies, contributing to open-source projects, or enjoying outdoor activities. I believe in continuous learning and regularly challenge myself with new skills and techniques.</p>
                </div>
            </div>
        </div>
    </section>
    
    <!-- Projects Section -->
    <section id="projects" class="py-16 px-4 bg-gray-100 bg-opacity-90 section-transition">
        <div class="max-w-4xl mx-auto">
            <h2 class="text-3xl font-bold mb-8 text-center text-blue-900">My Projects</h2>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <div class="bg-white p-6 rounded-lg shadow-lg transform hover:-translate-y-1 transition duration-300">
                    <div class="h-48 bg-blue-200 mb-4 rounded flex items-center justify-center">
                        <i class="fas fa-code text-5xl text-blue-500"></i>
                    </div>
                    <h3 class="text-xl font-bold mb-2 text-blue-800">Interactive Data Visualization</h3>
                    <p class="text-gray-600 mb-4">
                        A dashboard for visualizing complex datasets with interactive charts and filters.
                        Built with D3.js and React.
                    </p>
                    <div class="flex flex-wrap gap-2 mb-4">
                        <span class="px-2 py-1 bg-blue-100 text-blue-800 rounded text-sm">React</span>
                        <span class="px-2 py-1 bg-blue-100 text-blue-800 rounded text-sm">D3.js</span>
                        <span class="px-2 py-1 bg-blue-100 text-blue-800 rounded text-sm">TypeScript</span>
                    </div>
                    <a href="#" class="text-blue-600 hover:text-blue-800 font-medium">View Project →</a>
                </div>
                
                <div class="bg-white p-6 rounded-lg shadow-lg transform hover:-translate-y-1 transition duration-300">
                    <div class="h-48 bg-green-200 mb-4 rounded flex items-center justify-center">
                        <i class="fas fa-mobile-alt text-5xl text-green-600"></i>
                    </div>
                    <h3 class="text-xl font-bold mb-2 text-green-800">Mobile Health App</h3>
                    <p class="text-gray-600 mb-4">
                        A cross-platform mobile application for tracking health metrics and providing personalized recommendations.
                    </p>
                    <div class="flex flex-wrap gap-2 mb-4">
                        <span class="px-2 py-1 bg-green-100 text-green-800 rounded text-sm">React Native</span>
                        <span class="px-2 py-1 bg-green-100 text-green-800 rounded text-sm">Firebase</span>
                        <span class="px-2 py-1 bg-green-100 text-green-800 rounded text-sm">Node.js</span>
                    </div>
                    <a href="#" class="text-blue-600 hover:text-blue-800 font-medium">View Project →</a>
                </div>
                
                <div class="bg-white p-6 rounded-lg shadow-lg transform hover:-translate-y-1 transition duration-300">
                    <div class="h-48 bg-purple-200 mb-4 rounded flex items-center justify-center">
                        <i class="fas fa-robot text-5xl text-purple-500"></i>
                    </div>
                    <h3 class="text-xl font-bold mb-2 text-purple-800">AI Content Generator</h3>
                    <p class="text-gray-600 mb-4">
                        A web application that uses machine learning to generate content based on user prompts and preferences.
                    </p>
                    <div class="flex flex-wrap gap-2 mb-4">
                        <span class="px-2 py-1 bg-purple-100 text-purple-800 rounded text-sm">Python</span>
                        <span class="px-2 py-1 bg-purple-100 text-purple-800 rounded text-sm">TensorFlow</span>
                        <span class="px-2 py-1 bg-purple-100 text-purple-800 rounded text-sm">Flask</span>
                    </div>
                    <a href="#" class="text-blue-600 hover:text-blue-800 font-medium">View Project →</a>
                </div>
                
                <div class="bg-white p-6 rounded-lg shadow-lg transform hover:-translate-y-1 transition duration-300">
                    <div class="h-48 bg-yellow-200 mb-4 rounded flex items-center justify-center">
                        <i class="fas fa-shopping-cart text-5xl text-yellow-500"></i>
                    </div>
                    <h3 class="text-xl font-bold mb-2 text-yellow-800">E-Commerce Platform</h3>
                    <p class="text-gray-600 mb-4">
                        A full-featured online store with product management, cart functionality, and secure checkout.
                    </p>
                    <div class="flex flex-wrap gap-2 mb-4">
                        <span class="px-2 py-1 bg-yellow-100 text-yellow-800 rounded text-sm">Next.js</span>
                        <span class="px-2 py-1 bg-yellow-100 text-yellow-800 rounded text-sm">MongoDB</span>
                        <span class="px-2 py-1 bg-yellow-100 text-yellow-800 rounded text-sm">Stripe API</span>
                    </div>
                    <a href="#" class="text-blue-600 hover:text-blue-800 font-medium">View Project →</a>
                </div>
            </div>
        </div>
    </section>
    
    <!-- Skills Section -->
    <section id="skills" class="py-16 px-4 bg-white bg-opacity-90 section-transition">
        <div class="max-w-4xl mx-auto">
            <h2 class="text-3xl font-bold mb-8 text-center text-blue-900">My Skills</h2>
            
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                <div class="bg-blue-50 p-6 rounded-lg shadow">
                    <h3 class="text-xl font-bold mb-4 text-blue-800 text-center">Frontend</h3>
                    <ul class="space-y-3">
                        <li class="flex items-center">
                            <i class="fab fa-html5 text-orange-500 mr-2"></i>
                            <span>HTML5 / CSS3</span>
                        </li>
                        <li class="flex items-center">
                            <i class="fab fa-js text-yellow-500 mr-2"></i>
                            <span>JavaScript / TypeScript</span>
                        </li>
                        <li class="flex items-center">
                            <i class="fab fa-react text-blue-400 mr-2"></i>
                            <span>React / Next.js</span>
                        </li>
                        <li class="flex items-center">
                            <i class="fab fa-vuejs text-green-500 mr-2"></i>
                            <span>Vue.js / Nuxt.js</span>
                        </li>
                        <li class="flex items-center">
                            <i class="fab fa-sass text-pink-500 mr-2"></i>
                            <span>SASS / Tailwind CSS</span>
                        </li>
                    </ul>
                </div>
                
                <div class="bg-blue-50 p-6 rounded-lg shadow">
                    <h3 class="text-xl font-bold mb-4 text-blue-800 text-center">Backend</h3>
                    <ul class="space-y-3">
                        <li class="flex items-center">
                            <i class="fab fa-node-js text-green-600 mr-2"></i>
                            <span>Node.js / Express</span>
                        </li>
                        <li class="flex items-center">
                            <i class="fab fa-python text-blue-500 mr-2"></i>
                            <span>Python / Django</span>
                        </li>
                        <li class="flex items-center">
                            <i class="fas fa-database text-blue-500 mr-2"></i>
                            <span>MongoDB / PostgreSQL</span>
                        </li>
                        <li class="flex items-center">
                            <i class="fas fa-server text-red-500 mr-2"></i>
                            <span>REST API / GraphQL</span>
                        </li>
                        <li class="flex items-center">
                            <i class="fas fa-lock text-gray-700 mr-2"></i>
                            <span>Authentication / Security</span>
                        </li>
                    </ul>
                </div>
                
                <div class="bg-blue-50 p-6 rounded-lg shadow">
                    <h3 class="text-xl font-bold mb-4 text-blue-800 text-center">Tools & Others</h3>
                    <ul class="space-y-3">
                        <li class="flex items-center">
                            <i class="fab fa-git-alt text-orange-600 mr-2"></i>
                            <span>Git / GitHub</span>
                        </li>
                        <li class="flex items-center">
                            <i class="fab fa-docker text-blue-500 mr-2"></i>
                            <span>Docker / Kubernetes</span>
                        </li>
                        <li class="flex items-center">
                            <i class="fab fa-aws text-orange-500 mr-2"></i>
                            <span>AWS / Cloud Services</span>
                        </li>
                        <li class="flex items-center">
                            <i class="fas fa-vial text-purple-500 mr-2"></i>
                            <span>Jest / Testing</span>
                        </li>
                        <li class="flex items-center">
                            <i class="fas fa-pencil-ruler text-blue-500 mr-2"></i>
                            <span>UI/UX Design / Figma</span>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </section>
    
    <!-- Contact Section -->
    <section id="contact" class="py-16 px-4 bg-gray-100 bg-opacity-90 section-transition">
        <div class="max-w-4xl mx-auto">
            <h2 class="text-3xl font-bold mb-8 text-center text-blue-900">Get In Touch</h2>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <div>
                    <form class="bg-white p-6 rounded-lg shadow-lg">
                        <div class="mb-4">
                            <label for="name" class="block mb-2 text-gray-700">Name</label>
                            <input type="text" id="name" class="w-full p-3 border border-gray-300 rounded focus:outline-none focus:ring-2 focus:ring-blue-400">
                        </div>
                        <div class="mb-4">
                            <label for="email" class="block mb-2 text-gray-700">Email</label>
                            <input type="email" id="email" class="w-full p-3 border border-gray-300 rounded focus:outline-none focus:ring-2 focus:ring-blue-400">
                        </div>
                        <div class="mb-4">
                            <label for="subject" class="block mb-2 text-gray-700">Subject</label>
                            <input type="text" id="subject" class="w-full p-3 border border-gray-300 rounded focus:outline-none focus:ring-2 focus:ring-blue-400">
                        </div>
                        <div class="mb-4">
                            <label for="message" class="block mb-2 text-gray-700">Message</label>
                            <textarea id="message" rows="4" class="w-full p-3 border border-gray-300 rounded focus:outline-none focus:ring-2 focus:ring-blue-400"></textarea>
                        </div>
                        <button type="submit" class="w-full px-6 py-3 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition shadow-lg">Send Message</button>
                    </form>
                </div>
                
                <div>
                    <div class="bg-blue-50 p-6 rounded-lg shadow-lg mb-6">
                        <h3 class="text-xl font-bold mb-4 text-blue-800">Contact Information</h3>
                        <ul class="space-y-3">
                            <li class="flex items-center">
                                <i class="fas fa-envelope text-blue-500 mr-2"></i>
                                <span>john.doe@example.com</span>
                            </li>
                            <li class="flex items-center">
                                <i class="fas fa-phone text-blue-500 mr-2"></i>
                                <span>+1 (555) 123-4567</span>
                            </li>
                            <li class="flex items-center">
                                <i class="fas fa-map-marker-alt text-blue-500 mr-2"></i>
                                <span>San Francisco, CA, USA</span>
                            </li>
                        </ul>
                    </div>
                    
                    <div class="bg-blue-50 p-6 rounded-lg shadow-lg">
                        <h3 class="text-xl font-bold mb-4 text-blue-800">Connect With Me</h3>
                        <div class="flex space-x-4">
                            <a href="#" class="text-gray-700 hover:text-blue-600 transition">
                                <i class="fab fa-github text-2xl"></i>
                            </a>
                            <a href="#" class="text-gray-700 hover:text-blue-600 transition">
                                <i class="fab fa-linkedin text-2xl"></i>
                            </a>
                            <a href="#" class="text-gray-700 hover:text-blue-600 transition">
                                <i class="fab fa-twitter text-2xl"></i>
                            </a>
                            <a href="#" class="text-gray-700 hover:text-blue-600 transition">
                                <i class="fab fa-dev text-2xl"></i>
                            </a>
                            <a href="#" class="text-gray-700 hover:text-blue-600 transition">
                                <i class="fab fa-medium text-2xl"></i>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
    
    <!-- Footer -->
    <footer class="py-8 px-4 bg-gray-800 text-white text-center section-transition">
        <div class="max-w-4xl mx-auto">
            <p class="mb-4"> 2025 John Doe. All Rights Reserved.</p>
            <p class="text-gray-400">Made with <i class="fas fa-heart text-red-500"></i> and lots of coffee</p>
        </div>
    </footer>
</Layout>
