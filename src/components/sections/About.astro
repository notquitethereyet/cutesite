---
interface Props {
  initials?: string;
  paragraphs?: string[];
}

const { 
  initials = "JD",
  paragraphs = [
    "Hello! I'm a passionate developer with expertise in creating interactive web experiences. I specialize in combining creative design with technical excellence to build engaging applications.",
    "With over 5 years of experience in the industry, I've worked on a diverse range of projects from small business websites to complex enterprise applications. My approach combines clean code, intuitive user experiences, and innovative problem-solving.",
    "When I'm not coding, you can find me exploring new technologies, contributing to open-source projects, or enjoying outdoor activities. I believe in continuous learning and regularly challenge myself with new skills and techniques."
  ]
} = Astro.props;
---

<section id="about" class="py-16 px-4 bg-white bg-opacity-90 section-transition">
  <div class="max-w-4xl mx-auto">
    <h2 class="text-3xl font-bold mb-8 text-center text-blue-900">About Me</h2>
    <div class="flex flex-col md:flex-row gap-8 items-center">
      <div class="md:w-1/3">
        <div class="w-64 h-64 rounded-full bg-blue-200 mx-auto flex items-center justify-center">
          <span class="text-6xl text-blue-500">{initials}</span>
        </div>
      </div>
      <div class="md:w-2/3">
        {paragraphs.map((paragraph) => (
          <p class="mb-4">{paragraph}</p>
        ))}
      </div>
    </div>
  </div>
</section>
