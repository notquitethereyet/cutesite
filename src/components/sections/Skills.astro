---
interface Skill {
  icon: string;
  name: string;
  iconColor?: string;
}

interface SkillCategory {
  title: string;
  skills: Skill[];
}

interface Props {
  categories?: SkillCategory[];
}

const defaultCategories: SkillCategory[] = [
  {
    title: "Frontend",
    skills: [
      { icon: "fa-html5", name: "HTML5 / CSS3", iconColor: "text-orange-500" },
      { icon: "fa-js", name: "JavaScript / TypeScript", iconColor: "text-yellow-500" },
      { icon: "fa-react", name: "React / Next.js", iconColor: "text-blue-400" },
      { icon: "fa-vuejs", name: "Vue.js / Nuxt.js", iconColor: "text-green-500" },
      { icon: "fa-sass", name: "SASS / Tailwind CSS", iconColor: "text-pink-500" }
    ]
  },
  {
    title: "Backend",
    skills: [
      { icon: "fa-node-js", name: "Node.js / Express", iconColor: "text-green-600" },
      { icon: "fa-python", name: "Python / Django", iconColor: "text-blue-500" },
      { icon: "fa-database", name: "MongoDB / PostgreSQL", iconColor: "text-blue-500" },
      { icon: "fa-server", name: "REST API / GraphQL", iconColor: "text-red-500" },
      { icon: "fa-lock", name: "Authentication / Security", iconColor: "text-gray-700" }
    ]
  },
  {
    title: "Tools & Others",
    skills: [
      { icon: "fa-git-alt", name: "Git / GitHub", iconColor: "text-orange-600" },
      { icon: "fa-docker", name: "Docker / Kubernetes", iconColor: "text-blue-500" },
      { icon: "fa-aws", name: "AWS / Cloud Services", iconColor: "text-orange-500" },
      { icon: "fa-vial", name: "Jest / Testing", iconColor: "text-purple-500" },
      { icon: "fa-pencil-ruler", name: "UI/UX Design / Figma", iconColor: "text-blue-500" }
    ]
  }
];

const { categories = defaultCategories } = Astro.props;
---

<section id="skills" class="py-16 px-4 bg-white bg-opacity-90 section-transition">
  <div class="max-w-4xl mx-auto">
    <h2 class="text-3xl font-bold mb-8 text-center text-blue-900">My Skills</h2>
    
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {categories.map((category) => (
        <div class="bg-blue-50 p-6 rounded-lg shadow">
          <h3 class="text-xl font-bold mb-4 text-blue-800 text-center">{category.title}</h3>
          <ul class="space-y-3">
            {category.skills.map((skill) => (
              <li class="flex items-center">
                <i class={`fab ${skill.icon} ${skill.iconColor} mr-2`}></i>
                <span>{skill.name}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>
