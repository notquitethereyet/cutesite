---
interface ContactInfo {
  email: string;
  phone: string;
  location: string;
}

interface SocialLink {
  platform: string;
  icon: string;
  url: string;
}

interface Props {
  contactInfo?: ContactInfo;
  socialLinks?: SocialLink[];
}

const defaultContactInfo: ContactInfo = {
  email: "john.doe@example.com",
  phone: "+1 (555) 123-4567",
  location: "San Francisco, CA, USA"
};

const defaultSocialLinks: SocialLink[] = [
  { platform: "GitHub", icon: "fa-github", url: "#" },
  { platform: "LinkedIn", icon: "fa-linkedin", url: "#" },
  { platform: "Twitter", icon: "fa-twitter", url: "#" },
  { platform: "Dev.to", icon: "fa-dev", url: "#" },
  { platform: "Medium", icon: "fa-medium", url: "#" }
];

const { 
  contactInfo = defaultContactInfo,
  socialLinks = defaultSocialLinks
} = Astro.props;
---

<section id="contact" class="py-16 px-4 bg-gray-100 bg-opacity-90 section-transition">
  <div class="max-w-4xl mx-auto">
    <h2 class="text-3xl font-bold mb-8 text-center text-blue-900">Get In Touch</h2>
    
    <div class="flex flex-col items-center">
      <div class="bg-blue-50 p-6 rounded-lg shadow-lg mb-6 max-w-md w-full">
        <h3 class="text-xl font-bold mb-4 text-blue-800">Contact Information</h3>
        <ul class="space-y-3">
          <li class="flex items-center">
            <i class="fas fa-envelope text-blue-500 mr-2"></i>
            <span>{contactInfo.email}</span>
          </li>
          <li class="flex items-center">
            <i class="fas fa-phone text-blue-500 mr-2"></i>
            <span>{contactInfo.phone}</span>
          </li>
          <li class="flex items-center">
            <i class="fas fa-map-marker-alt text-blue-500 mr-2"></i>
            <span>{contactInfo.location}</span>
          </li>
        </ul>
      </div>
      
      <div class="bg-blue-50 p-6 rounded-lg shadow-lg max-w-md w-full">
        <h3 class="text-xl font-bold mb-4 text-blue-800">Connect With Me</h3>
        <div class="flex justify-center space-x-6">
          {socialLinks.map((social) => (
            <a href={social.url} class="text-gray-700 hover:text-blue-600 transition" aria-label={social.platform}>
              <i class={`fab ${social.icon} text-2xl`}></i>
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
