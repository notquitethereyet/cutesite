---
interface Project {
  title: string;
  description: string;
  icon: string;
  iconColor: string;
  bgColor: string;
  textColor: string;
  tags: string[];
  link?: string;
}

interface Props {
  projects?: Project[];
}

const defaultProjects: Project[] = [
  {
    title: "Neural Network IDS with Reduced Feature Vectors",
    description: "Developed a neural network-based Intrusion Detection System that improved detection accuracy with custom feature selection. Achieved 92.20% accuracy on UNSW-NB15 and 95.14% on NSL-KDD, outperforming previous benchmarks.",
    icon: "fa-shield-alt",
    iconColor: "text-blue-600", 
    bgColor: "bg-blue-50", 
    textColor: "text-blue-800", 
    tags: ["Neural Networks", "Security", "Feature Selection", "Python"]
  },
  {
    title: "Scalable RAG System with Pinecone and Groq",
    description: "Built a modular Retrieval-Augmented Generation system using Pinecone for vector storage and Groq for fast inference, enabling real-time, context-aware querying of large PDF datasets with a 35% boost in search relevance.",
    icon: "fa-brain",
    iconColor: "text-blue-600", 
    bgColor: "bg-blue-50", 
    textColor: "text-blue-800", 
    tags: ["Artificial Intelligence", "Machine Learning", "LLMs", "Vector Search"]
  },
  {
    title: "Automation and Full Stack Development",
    description: "Developed automation workflows and websites dealing with healthcare data for my company.",
    icon: "fa-heartbeat",
    iconColor: "text-blue-600", 
    bgColor: "bg-blue-50", 
    textColor: "text-blue-800", 
    tags: ["Make.com", "Supabase", "Google APIs", "Automation"]
  },
  {
    title: "NixOS Configuration",
    description: "NixOS configuration for reproducible development environments and system management.",
    icon: "fa-terminal",
    iconColor: "text-blue-600", 
    bgColor: "bg-blue-50", 
    textColor: "text-blue-800", 
    tags: ["NixOS", "Linux", "DevOps", "Configuration"]
  }
];

const { projects = defaultProjects } = Astro.props;
---

<section id="projects" class="py-16 px-4 bg-white bg-opacity-90 section-transition">
  <div class="max-w-4xl mx-auto">
    <h2 class="text-3xl font-bold mb-8 text-center text-blue-900">My Projects</h2>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {projects.map((project) => (
        <div class={`${project.bgColor} p-6 rounded-lg shadow transform hover:-translate-y-1 transition duration-300`}>
          <div class="flex items-start mb-4">
            <div class={`w-10 h-10 flex items-center justify-center mr-4`}>
              <i class={`fas ${project.icon} text-2xl ${project.iconColor}`}></i>
            </div>
            <div>
              <h3 class={`text-xl font-bold mb-2 ${project.textColor}`}>{project.title}</h3>
              <p class="text-gray-600 mb-4">{project.description}</p>
            </div>
          </div>
          <div class="flex flex-wrap gap-2 mt-auto">
            {project.tags.map((tag) => (
              <span class={`text-xs px-2 py-1 rounded-full bg-blue-100 text-blue-800`}>
                {tag}
              </span>
            ))}
          </div>
          {project.link && (
            <a href={project.link} class={`mt-4 inline-block text-sm ${project.iconColor} hover:underline`}>
              Learn more <i class="fas fa-arrow-right ml-1"></i>
            </a>
          )}
        </div>
      ))}
    </div>
  </div>
</section>
